/*
 * Exercício: Exibição de Matriz com Laços
 * Tema: Matrizes
 *
 * Objetivo:
 * Percorrer e exibir todos os elementos
 * de uma matriz utilizando estruturas de repetição.
 *
 * Conceitos praticados:
 * - Matrizes
 * - Laços aninhados
 * - Índices de linha e coluna
 */

#include <stdio.h>

int main() {

    int matriz[3][3] = {
        {1, 2, 3},
        {4, 5, 6},
        {7, 8, 9}
    };

    printf("Matriz 3x3:\n\n");

    for (int linha = 0; linha < 3; linha++) {

        for (int coluna = 0; coluna < 3; coluna++) {
            printf("%d\t", matriz[linha][coluna]);
        }

        printf("\n");
    }

    return 0;
}
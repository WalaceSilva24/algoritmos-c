 * Tema: Funções
 *
 * Objetivo:
 * Criar uma função que receba dois números e retorne o maior deles.
 *
 * Conceitos praticados:
 * - Declaração de funções
 * - Parâmetros
 * - Retorno de valores
 * - Estruturas condicionais
 * - Entrada e saída de dados
 */

#include <stdio.h>

/*
 * Recebe dois números reais e retorna o maior deles.
 */
float maior(float num1, float num2) {

    if (num1 > num2) {
        return num1;
    }

    return num2;
}

int main() {

    float x, y;
    float resultado;

    printf("Digite o primeiro valor: ");
    scanf("%f", &x);

    printf("Digite o segundo valor: ");
    scanf("%f", &y);

    // Chama a função e armazena o retorno
    resultado = maior(x, y);

    printf("\nMaior valor: %.2f\n", resultado);

    return 0;
}
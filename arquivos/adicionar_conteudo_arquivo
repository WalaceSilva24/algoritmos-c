/*
 * Exercício: Adicionar Conteúdo ao Arquivo
 * Tema: Arquivos
 *
 * Objetivo:
 * Acrescentar novas informações a um arquivo
 * sem apagar os dados existentes.
 *
 * Conceitos praticados:
 * - fopen() modo append
 * - fprintf()
 * - Persistência de dados
 */

#include <stdio.h>

int main() {

    FILE *arquivo;

    arquivo = fopen("mensagem.txt", "a");

    if (arquivo == NULL) {
        printf("Erro ao abrir o arquivo.\n");
        return 1;
    }

    fprintf(arquivo, "Nova linha adicionada pelo programa.\n");

    fclose(arquivo);

    printf("Conteudo adicionado com sucesso.\n");

    return 0;
}
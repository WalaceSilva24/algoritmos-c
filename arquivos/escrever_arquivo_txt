/*
 * Exercício: Escrita em Arquivo TXT
 * Tema: Arquivos
 *
 * Objetivo:
 * Criar um arquivo texto e gravar informações nele.
 *
 * Conceitos praticados:
 * - Arquivos
 * - fopen()
 * - fprintf()
 * - fclose()
 * - Tratamento de erros
 */

#include <stdio.h>

int main() {

    FILE *arquivo;

    arquivo = fopen("mensagem.txt", "w");

    if (arquivo == NULL) {
        printf("Erro ao criar o arquivo.\n");
        return 1;
    }

    fprintf(arquivo, "Ola, mundo!\n");
    fprintf(arquivo, "Este texto foi gravado por um programa em C.\n");

    fclose(arquivo);

    printf("Arquivo criado com sucesso.\n");

    return 0;
}
/*
 * Exercício: Cadastro de Pessoas em Arquivo
 * Tema: Arquivos
 *
 * Objetivo:
 * Registrar nomes informados pelo usuário
 * em um arquivo texto.
 *
 * Conceitos praticados:
 * - Arquivos
 * - Entrada de dados
 * - Persistência
 */

#include <stdio.h>

int main() {

    FILE *arquivo;
    char nome[50];

    arquivo = fopen("pessoas.txt", "a");

    if (arquivo == NULL) {
        printf("Erro ao abrir o arquivo.\n");
        return 1;
    }

    printf("Digite um nome: ");
    fgets(nome, sizeof(nome), stdin);

    fprintf(arquivo, "%s", nome);

    fclose(arquivo);

    printf("Pessoa cadastrada com sucesso.\n");

    return 0;
}